    "@tarojs/runtime": "^4.0.0",
    "@tarojs/taro": "^4.0.0",
    "date-fns": "^3.6.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@babel/preset-react": "^7.29.7",
    "@tarojs/cli": "^4.0.0",
    "@tarojs/webpack5-runner": "^4.0.0",
    "@types/react": "^18.3.12",
    "@types/webpack-env": "^1.18.4",
    "autoprefixer": "^10.4.20",
    "babel-preset-taro": "^4.0.0",
    "postcss": "^8.4.49",
