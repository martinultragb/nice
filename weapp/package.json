{
  "name": "fitness-weapp",
  "version": "1.0.0",
  "private": true,
  "description": "健身记录小程序",
  "templateInfo": {
    "name": "default",
    "typescript": true,
    "css": "tailwind"
  },
  "scripts": {
    "dev:weapp": "taro build --type weapp --watch",
    "build:weapp": "taro build --type weapp && node fix-wxss.js",
