page{background-color:#f3f4f6;font-family:-apple-system,BlinkMacSystemFont,Segoe UI,Roboto,sans-serif}.container{padding:32rpx}.card{background-color:#fff;border-radius:16rpx;-webkit-box-shadow:0 2rpx 6rpx rgba(0,0,0,.1);box-shadow:0 2rpx 6rpx rgba(0,0,0,.1);margin-bottom:24rpx;padding:32rpx}.title{color:#1f2937;font-size:48rpx;font-weight:700;margin-bottom:32rpx}.subtitle{color:#374151;font-size:36rpx;font-weight:600;margin-bottom:24rpx}.text{color:#4b5563;font-size:32rpx}.text-muted{color:#9ca3af;font-size:28rpx}.btn{border-radius:16rpx;cursor:pointer;font-size:32rpx;font-weight:500;padding:24rpx 48rpx;text-align:center}.btn-primary{background-color:#3b82f6;color:#fff}.btn-secondary{background-color:#e5e7eb;color:#374151}.btn-success{background-color:#10b981;color:#fff}.btn-danger{background-color:#ef4444;color:#fff}.input{border:2rpx solid #d1d5db;border-radius:16rpx;font-size:32rpx;margin-bottom:24rpx;padding:24rpx;width:100%}.flex{display:-webkit-flex;display:-ms-flexbox;display:-webkit-box;display:flex}.flex-col{-webkit-flex-direction:column;-ms-flex-direction:column;flex-direction:column}.items-center{-webkit-align-items:center;-ms-flex-align:center;align-items:center}.justify-between{-webkit-justify-content:space-between;-ms-flex-pack:justify;justify-content:space-between}.gap-2{gap:16rpx}.gap-4{gap:32rpx}.mt-4{margin-top:32rpx}.mb-4{margin-bottom:32rpx}.mb-2{margin-bottom:16rpx}.p-4{padding:32rpx}